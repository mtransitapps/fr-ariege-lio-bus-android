{
    "default_route_id_enabled": true,
    "use_route_short_name_for_route_id": true,
    "default_route_long_name_enabled": true,
    "direction_finder_enabled": true,
    "direction_headsign_cleaners": [
        {
            "regex": "(?U)^([^-\\s]+\\s*[-\\s+]\\s*)+([^-\\s]+)$",
            "replacement": "$2",
            "comment": "Keep only after last '-' or ' '"
        },
        {
            "regex": "Tarascon",
            "ignore_case": true,
            "is_word": true,
            "replacement": "Tarascon-sur-Ariège"
        },
        {
            "regex": "Montsegur",
            "ignore_case": true,
            "is_word": true,
            "replacement": "Montségur"
        },
        {
            "regex": "(Girons|St Girons|Saint Girons)",
            "ignore_case": true,
            "is_word": true,
            "replacement": "St-Girons"
        },
        {
            "regex": "(Lary|St Lary|Saint Lary)",
            "ignore_case": true,
            "is_word": true,
            "replacement": "St-Lary"
        },
        {
            "regex": "(Lizier|St Lizier|Saint Lizier)",
            "ignore_case": true,
            "is_word": true,
            "replacement": "St-Lizier"
        }
    ],
    "trip_headsign_remove_via": true,
    "trip_headsign_cleaners": [
        {
            "regex": "^((?:(?! - )[\\s\\S])*)(\\s+-\\s+)(.+)$",
            "replacement": "$1: $3",
            "comment": "Keep 'city: location' (city more important when different than direction)"
        }
    ],
    "stop_name_cleaners": [
        {
            "regex": "^((?:(?! - )[\\s\\S])*)(\\s+-\\s+)(.+)$",
            "replacement": "$1: $3"
        }
    ]
}